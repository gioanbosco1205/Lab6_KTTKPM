{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/auth/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5060
        }
      ],
      "UpstreamPathTemplate": "/auth/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST" ],
      "RateLimitOptions": {
        "EnableRateLimiting": true,
        "Period": "1m",
        "Limit": 10,
        "PeriodTimespan": 60
      }
    },
    {
      "DownstreamPathTemplate": "/api/pricing",
      "DownstreamScheme": "http",
      "ServiceName": "PRICINGSERVICE",
      "UpstreamPathTemplate": "/pricing",
      "UpstreamHttpMethod": [ "GET" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer"
      },
      "FileCacheOptions": {
        "TtlSeconds": 15
      },
      "RateLimitOptions": {
        "EnableRateLimiting": true,
        "Period": "1s",
        "Limit": 5,
        "PeriodTimespan": 1
      }
    },
    {
      "DownstreamPathTemplate": "/api/pricing/{id}",
      "DownstreamScheme": "http",
      "ServiceName": "PRICINGSERVICE",
      "UpstreamPathTemplate": "/pricing/{id}",
      "UpstreamHttpMethod": [ "GET" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer"
      },
      "FileCacheOptions": {
        "TtlSeconds": 15
      },
      "RateLimitOptions": {
        "EnableRateLimiting": true,
        "Period": "1s",
        "Limit": 3,
        "PeriodTimespan": 1
      }
    },
    {
      "DownstreamPathTemplate": "/api/pricing",
      "DownstreamScheme": "http",
      "ServiceName": "PRICINGSERVICE",
      "UpstreamPathTemplate": "/pricing",
      "UpstreamHttpMethod": [ "POST" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer"
      },
      "RateLimitOptions": {
        "EnableRateLimiting": true,
        "Period": "1m",
        "Limit": 20,
        "PeriodTimespan": 60
      }
    },
    {
      "DownstreamPathTemplate": "/api/pricing/{id}",
      "DownstreamScheme": "http",
      "ServiceName": "PRICINGSERVICE",
      "UpstreamPathTemplate": "/pricing/{id}",
      "UpstreamHttpMethod": [ "PUT" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer"
      },
      "RateLimitOptions": {
        "EnableRateLimiting": true,
        "Period": "1m",
        "Limit": 15,
        "PeriodTimespan": 60
      }
    },
    {
      "DownstreamPathTemplate": "/api/pricing/{id}",
      "DownstreamScheme": "http",
      "ServiceName": "PRICINGSERVICE",
      "UpstreamPathTemplate": "/pricing/{id}",
      "UpstreamHttpMethod": [ "DELETE" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer"
      },
      "RateLimitOptions": {
        "EnableRateLimiting": true,
        "Period": "1m",
        "Limit": 5,
        "PeriodTimespan": 60
      }
    },
    {
      "DownstreamPathTemplate": "/api/policy",
      "DownstreamScheme": "http",
      "ServiceName": "POLICYSERVICE",
      "UpstreamPathTemplate": "/policy",
      "UpstreamHttpMethod": [ "GET" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer"
      },
      "FileCacheOptions": {
        "TtlSeconds": 15
      },
      "RateLimitOptions": {
        "EnableRateLimiting": true,
        "Period": "1s",
        "Limit": 2,
        "PeriodTimespan": 1
      }
    }
  ],

  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5050",

    "ServiceDiscoveryProvider": {
      "Type": "Eureka",
      "Host": "eureka",
      "Port": 8761
    },

    "RateLimitOptions": {
      "ClientIdHeader": "ClientId",
      "QuotaExceededMessage": "Rate limit exceeded. Please try again later.",
      "HttpStatusCode": 429,
      "DisableRateLimitHeaders": false
    }
  }
}